# Azure OpenAI — used by the "Extract Action Items with AI" feature
# These are baked into the client bundle at build time (Vite).
# For production, route through APIM instead of exposing keys client-side.
VITE_AOAI_ENDPOINT=https://your-resource.openai.azure.com
VITE_AOAI_API_KEY=your-api-key
VITE_AOAI_DEPLOYMENT=gpt-4o
